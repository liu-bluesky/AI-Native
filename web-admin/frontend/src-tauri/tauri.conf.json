{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI 员工工厂",
  "version": "0.1.0",
  "identifier": "com.ai-employee.factory",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI 员工工厂",
        "width": 1320,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": [
      "bot_workers/feishu_sdk_listener.py"
    ],
    "icon": []
  }
}
