# API 网关本地开发配置
# 优先使用 DATABASE_URL；若未设置，后端会回退到 DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME 组装连接串。

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_CORS_ALLOW_ORIGINS=*

CORE_STORE_BACKEND=postgres
USAGE_STORE_BACKEND=postgres

DATABASE_URL=postgresql://admin:changeme@127.0.0.1:5432/ai_employee

# 兼容写法（二选一即可）
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=admin
# DB_PASSWORD=changeme
# DB_NAME=ai_employee

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

SESSION_TTL=3600
MAX_MESSAGES=20
COMPRESSION_THRESHOLD=15
TOOL_TIMEOUT=60
MAX_TOOL_RETRIES=3

# 按需启用
# EXTERNAL_AGENT_RUNNER_URL=http://127.0.0.1:3931
# EXTERNAL_AGENT_CODEX_BIN=codex
# EXTERNAL_AGENT_CLAUDE_BIN=claude
# EXTERNAL_AGENT_GEMINI_BIN=gemini
