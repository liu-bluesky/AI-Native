# 本地连接器监听地址。
# 普通用户一般不需要修改，保持默认即可。
LOCAL_CONNECTOR_HOST=127.0.0.1
LOCAL_CONNECTOR_PORT=3931

# 平台接入信息。
# 使用“浏览器快捷接入”下载的一键包时，这些值通常已经由启动脚本自动注入，
# 普通用户不需要手动填写。
LOCAL_CONNECTOR_PLATFORM_URL=
LOCAL_CONNECTOR_PAIR_CODE=

# 设备显示名称。
# 不填写时，会自动用当前电脑名称作为默认值。
LOCAL_CONNECTOR_NAME=

# 对外上报给平台的访问地址。
# 一般保持空即可，由连接器自动推断。
LOCAL_CONNECTOR_ADVERTISED_URL=

# 心跳上报间隔，单位秒。
# 普通用户不建议修改。
LOCAL_CONNECTOR_HEARTBEAT_SEC=20

# 本地模型桥接配置。
# 如果你希望平台上的 AI 通过这台电脑调用本地模型
# （例如 Ollama / LM Studio / 本地 OpenAI 兼容服务），再填写下面这些值。
LOCAL_CONNECTOR_LLM_BASE_URL=
LOCAL_CONNECTOR_LLM_API_KEY=
LOCAL_CONNECTOR_LLM_MODELS=
LOCAL_CONNECTOR_LLM_DEFAULT_MODEL=
