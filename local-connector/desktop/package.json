{
  "name": "local-connector-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop shell for Local Connector",
  "author": "AI Employee",
  "main": "src/main.js",
  "scripts": {
    "prepare:runtime": "node scripts/prepare-runtime.js",
    "prepack": "npm run prepare:runtime",
    "predist:dir": "npm run prepare:runtime",
    "predist:mac": "npm run prepare:runtime",
    "predist:win": "npm run prepare:runtime",
    "predist:all": "npm run prepare:runtime",
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:dir": "electron-builder --dir",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --mac --win"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ai-employee.localconnector",
    "productName": "Local Connector",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "runtime/connector",
        "to": "connector",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "src/main.js"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
