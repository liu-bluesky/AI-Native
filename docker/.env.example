# PostgreSQL 连接配置
# DB_USER: 数据库用户名（示例：admin）
DB_USER=admin
# DB_PASSWORD: 数据库密码（示例：changeme）
DB_PASSWORD=changeme
# DB_NAME: 数据库名（示例：ai_employee）
DB_NAME=ai_employee
# DB_PORT: 数据库端口（默认：5432）
DB_PORT=5432

# Redis 逻辑库编号（容器内部固定连接 redis:6379）
REDIS_DB=0

# Core 业务存储后端：postgres | json
CORE_STORE_BACKEND=postgres

# Usage 使用日志存储后端：postgres | sqlite
USAGE_STORE_BACKEND=postgres

# API 启动时是否自动执行 PostgreSQL migration：true | false
AUTO_RUN_DB_MIGRATIONS=true
