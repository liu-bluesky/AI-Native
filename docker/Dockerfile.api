FROM python:3.12-slim

WORKDIR /app

COPY web-admin/api/pyproject.toml .
RUN pip install --no-cache-dir -e .

COPY web-admin/api/ .
COPY mcp-skills/ /app/mcp-skills/
COPY mcp-rules/ /app/mcp-rules/
COPY mcp-memory/ /app/mcp-memory/
COPY mcp-persona/ /app/mcp-persona/
COPY mcp-evolution/ /app/mcp-evolution/
COPY mcp-sync/ /app/mcp-sync/

EXPOSE 8000
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
