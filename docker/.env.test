# Test Docker Compose configuration for first-deployment verification
# This file is intentionally isolated from docker/.env and the default ai_employee stack.

DB_USER=admin
DB_PASSWORD=test_changeme
DB_NAME=ai_employee_test
DB_PORT=55432
REDIS_DB=0
CORE_STORE_BACKEND=postgres
USAGE_STORE_BACKEND=postgres
AUTO_RUN_DB_MIGRATIONS=true
HOST_API_PORT=8100
HOST_FRONTEND_PORT=3100

# Initial super-admin account used by README.test-docker.md commands.
# The backend enforces username=admin for first initialization.
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=test123456
INIT_ADMIN_DISPLAY_NAME=测试超级管理员
