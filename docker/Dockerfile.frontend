FROM node:20-alpine AS build

WORKDIR /app
ARG VITE_SHOW_LOCAL_RUNTIME_SETTINGS=false
ENV VITE_SHOW_LOCAL_RUNTIME_SETTINGS=${VITE_SHOW_LOCAL_RUNTIME_SETTINGS}
COPY web-admin/frontend/package.json web-admin/frontend/package-lock.json* ./
RUN npm install
COPY web-admin/frontend/ .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
