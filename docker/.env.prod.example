# 镜像地址
API_IMAGE=ai_employee-api:latest
FRONTEND_IMAGE=ai_employee-frontend:latest

# 对外端口
HOST_API_PORT=8000
HOST_FRONTEND_PORT=3000

# PostgreSQL
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=ai_employee
DB_PORT=5432

# Redis
REDIS_DB=0

# 存储后端
CORE_STORE_BACKEND=postgres
USAGE_STORE_BACKEND=postgres

# 是否自动执行 PostgreSQL migration
AUTO_RUN_DB_MIGRATIONS=true
