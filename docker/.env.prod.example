# AI 员工工厂 Docker 公开发布模板
# 默认使用 Docker Hub 单仓库多 tag：lantianliu/ai-employee:<component>-<version>

# 镜像地址
API_IMAGE=docker.io/lantianliu/ai-employee:api-1.0.1
FRONTEND_IMAGE=docker.io/lantianliu/ai-employee:frontend-1.0.1
POSTGRES_IMAGE=docker.io/lantianliu/ai-employee:postgres-17
REDIS_IMAGE=docker.io/lantianliu/ai-employee:redis-7-alpine

# 对外端口；如果本机端口冲突，可以改成 3001 / 8001 / 15432
HOST_API_PORT=8000
HOST_FRONTEND_PORT=3000
DB_PORT=5432

# 前端是否展示本地开发专用设置项（如项目工作区、AI 入口文件）
VITE_SHOW_LOCAL_RUNTIME_SETTINGS=false

# PostgreSQL；正式环境务必修改 DB_PASSWORD
DB_USER=admin
DB_PASSWORD=change-this-password-before-production
DB_NAME=ai_employee

# Redis
REDIS_DB=0

# 存储后端
CORE_STORE_BACKEND=postgres
USAGE_STORE_BACKEND=postgres

# 是否自动执行 PostgreSQL migration
AUTO_RUN_DB_MIGRATIONS=true

# 方案B：CLI 在线安装会持久化到 compose volume，并在容器内映射到 /app/.ai-employee/cli-toolchain
